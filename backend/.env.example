# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/shiftcover?schema=public"

# Twilio SMS (optional - leave empty to disable SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Secret used to sign auth tokens (use a long random string)
JWT_SECRET=

# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGIN=http://localhost:3000

PORT=3001
